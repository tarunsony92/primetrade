PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://primetrade_user:your_password_here@cluster0.xxxxx.mongodb.net/primetrade?retryWrites=true&w=majority
JWT_SECRET=primetrade-secret-key-2024-production
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:3000

# MongoDB Atlas Setup Instructions:
# 1. Go to: https://www.mongodb.com/cloud/atlas
# 2. Sign up for FREE account
# 3. Create a FREE cluster (AWS, ap-south-1)
# 4. Create database user (username: primetrade_user)
# 5. Allow network access from anywhere
# 6. Click Connect → Drivers → Node.js
# 7. Copy connection string
# 8. Replace PASSWORD with your actual password
# 9. Add /primetrade before the ? for database name
# 10. Update MONGODB_URI above and save
